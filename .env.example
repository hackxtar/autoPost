# Google Gemini API Configuration
# Required: Get your API key from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Meta Graph API Configuration (Facebook & Instagram)
# Optional: Required for actual publishing to social platforms
# Get these from https://developers.facebook.com/

# Facebook Page Access Token (NOT a User token)
# Run: node get-page-token.js to exchange your User token for a Page token
FB_PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here

# Facebook Page ID
FB_PAGE_ID=your_facebook_page_id_here

# Instagram Business Account ID
IG_BUSINESS_ID=your_instagram_business_account_id_here

# Optional: Used by get-page-token.js to generate a long-lived Page token
# Get these from your app at https://developers.facebook.com/apps
FB_APP_ID=your_app_id_here
FB_APP_SECRET=your_app_secret_here

# Image Hosting (imgbb - free, needed to get a public URL for Instagram)
# Get a free API key at https://api.imgbb.com/ (takes 30 seconds, no credit card)
IMGBB_API_KEY=your_imgbb_api_key_here
